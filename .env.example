# =============================================================================
# Secrets — required, no defaults, must be set in .env
# =============================================================================

# OpenAI (required unless USE_AZURE_OPENAI=true)
OPENAI_API_KEY=sk-your-key-here

# Azure OpenAI (required if USE_AZURE_OPENAI=true)
USE_AZURE_OPENAI=false
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-azure-api-key
AZURE_DEPLOYMENT_NAME=your-deployment-name
AZURE_API_VERSION=2024-02-01

# CrewAI tracing
CREWAI_TRACING_ENABLED=false

# =============================================================================
# App overrides — optional, defaults are in settings.toml
# =============================================================================

# [app]
# APP_NAME=System Design Mentor API
# APP_DESCRIPTION=AI-powered architecture analysis and recommendations
# APP_VERSION=1.0.0
# APP_ENVIRONMENT=development

# [server]
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# SERVER_RELOAD=true

# [cors]
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# CORS_CREDENTIALS=true
# CORS_METHODS=*
# CORS_HEADERS=*

# [logging]
# LOGGING_LOG_LEVEL=INFO
# LOGGING_NOISY_LOGGERS=httpx,httpcore,openai,anthropic,litellm,crewai

# [chat]
# CHAT_MODEL=openai/gpt-4o
# CHAT_TEMPERATURE=0.3
# CHAT_MAX_TOKENS=1024

# [azure_llm]
# AZURE_LLM_TEMPERATURE=1.0
# AZURE_LLM_TOP_P=1.0
# AZURE_LLM_MAX_COMPLETION_TOKENS=4096

# [reviewer]
# REVIEWER_MAX_FILE_SIZE_MB=5

# [storage]
# STORAGE_DB_PATH=/path/to/db.sqlite
