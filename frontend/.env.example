# ---------------------------------------------------------------------------
# All configuration is driven by REACT_APP_* environment variables.
# Values are baked into the bundle at build time (CRA convention).
# Copy this file to .env and set the values you need.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL for the backend API.
# Default: /api/v1 (relative — works with the dev proxy in development)
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1

# Review submission endpoint path (appended to REACT_APP_API_BASE_URL).
# Default: /review
# REACT_APP_SUBMIT_ENDPOINT=/review

# Follow-up chat endpoint path (appended to REACT_APP_API_BASE_URL).
# Default: /chat
# REACT_APP_CHAT_ENDPOINT=/chat

# ---------------------------------------------------------------------------
# UI Text
# ---------------------------------------------------------------------------

# Application title shown in the header.
# Default: System Design Mentor
# REACT_APP_APP_TITLE=System Design Mentor

# Subtitle shown below the title.
# Default: AI-powered architecture analysis and recommendations
# REACT_APP_APP_SUBTITLE=AI-powered architecture analysis and recommendations

# Name shown in the streaming indicator and assistant chat bubbles.
# Default: Architect Assistant
# REACT_APP_ASSISTANT_NAME=Architect Assistant

# Placeholder text in the initial document input.
# Default: Paste your design document here or upload a file...
# REACT_APP_INPUT_PLACEHOLDER=Paste your design document here or upload a file...

# Placeholder text in the follow-up chat input.
# Default: Ask a follow-up question about the review...
# REACT_APP_CHAT_PLACEHOLDER=Ask a follow-up question about the review...

# Label on the submit button.
# Default: Review Design
# REACT_APP_SUBMIT_BUTTON_TEXT=Review Design

# Message shown when no conversation has started yet.
# Default: Submit a design document to get started with your architectural review
# REACT_APP_EMPTY_STATE_MESSAGE=Submit a design document to get started with your architectural review

# ---------------------------------------------------------------------------
# File Upload
# ---------------------------------------------------------------------------

# Maximum upload file size in megabytes.
# Default: 5
# REACT_APP_MAX_FILE_SIZE_MB=5
